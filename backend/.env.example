# Copie este arquivo para ".env" (sem o .example) e cole suas chaves gratuitas de IA.
# Você pode configurar uma ou várias - quanto mais tiver, mais a ferramenta consegue
# alternar entre elas quando uma bater a cota gratuita do dia.

# Google Gemini - pegue a sua em: https://aistudio.google.com/apikey
GEMINI_API_KEY=cole_sua_chave_aqui

# Groq - pegue a sua em: https://console.groq.com/keys
GROQ_API_KEY=cole_sua_chave_aqui

# NVIDIA Build (NIM) - pegue a sua em: https://build.nvidia.com
NVIDIA_API_KEY=cole_sua_chave_aqui

# Opcional: coloque "true" só se estiver desenvolvendo/depurando a ferramenta.
# Deixe "false" (ou apague a linha) no uso normal do dia a dia.
PROSPECCAO_DEBUG=false
